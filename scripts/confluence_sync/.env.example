# Atlassian Confluence Cloud 인증 정보
# 1. https://id.atlassian.com/manage-profile/security/api-tokens 에서 토큰 생성
# 2. 이 파일을 .env 로 복사 후 값 채우기
#    cp .env.example .env
# 3. .env 는 .gitignore 로 제외됨

ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-api-token-here

# (선택) base URL 오버라이드 — 비워두면 sync_config.json 의 confluence_base_url 사용
# CONFLUENCE_BASE_URL=https://woolimi.atlassian.net
